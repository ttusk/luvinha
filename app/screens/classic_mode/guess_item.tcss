GuessItem {
    height: 3;
    width: 100%;
    content-align: center middle;
    text-style: bold;
}

#guess-word {
    width: 100%;
    height: 1;
    color: $text;
    text-align: center;
    text-style: bold;
}

#guess-progress {
    width: 100%;
    height: 1;
    margin: 0;
    padding: 0;
}

#guess-score {
    width: 100%;
    height: 1;
    color: $text-muted;
    text-align: center;
}